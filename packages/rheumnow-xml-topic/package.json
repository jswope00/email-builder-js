{
  "name": "@usewaypoint/rheumnow-xml-topic",
  "version": "0.0.1",
  "description": "RheumNow admin terms parsing and topic-filtered XML feed URLs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup ./src/index.ts --outDir dist --format cjs,esm --dts"
  },
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^4.3.2"
  },
  "devDependencies": {
    "tsup": "^6.0.0"
  }
}
