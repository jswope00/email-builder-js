{
  "name": "@nattusia/block-xml-feed",
  "version": "0.0.3",
  "description": "Universal XML feed block for EmailBuilder",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup ./src/index.tsx --outDir dist --format cjs,esm --dts"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^16 || ^17 || ^18",
    "zod": "^3"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.2"
  },
  "devDependencies": {
    "tsup": "^6.0.0"
  }
}
